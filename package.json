{
  "name": "football-2026",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "cp -R public .next/standalone/public && mkdir -p .next/standalone/.next && cp -R .next/static .next/standalone/.next/static",
    "start": "HOSTNAME=0.0.0.0 node .next/standalone/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "flag-icons": "7.5.0",
    "lucide-react": "1.8.0",
    "motion": "12.38.0",
    "next": "16.2.4",
    "qrcode-generator": "2.0.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-svg-worldmap": "2.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/dom": "latest",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "@vitest/coverage-v8": "latest",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "latest",
    "husky": "9.1.7",
    "jsdom": "latest",
    "lint-staged": "16.4.0",
    "playwright": "1.59.1",
    "prettier": "3.8.3",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3",
    "vitest": "4.1.4"
  }
}
